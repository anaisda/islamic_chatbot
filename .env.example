# Copier ce fichier en .env et remplir les valeurs

# Clé OpenAI (obligatoire pour les réponses)
OPENAI_API_KEY=sk-...

# Chemin vers ton fichier FAISS (créé dans Colab)
FAISS_INDEX_PATH=./islamic_faiss_index.pkl

# Ou chemin vers ChromaDB si tu utilises ChromaDB
# CHROMADB_PATH=./IslamicChatbot_ChromaDB

# Port du serveur (défaut: 5000)
PORT=5000
